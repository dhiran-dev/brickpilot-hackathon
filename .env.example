# ============================================================
# BrickPilot — environment template
# Copy to .env.local and fill in. NEVER commit the filled file.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Design contract rollout ---
# V3 is the application default for every account. Set this to v2 only for an
# emergency rollback. v3_internal remains available for a future partial rollout.
BRICKPILOT_DESIGN_ROLLOUT_MODE=v3_ga
BRICKPILOT_ROLLOUT_EPOCH=v3-ga
BRICKPILOT_V3_OWNER_ALLOWLIST=

# --- Database (SELF-HOSTED Postgres, not Neon) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/brickpilot

# --- Auth (better-auth) — public signup is DISABLED; only seeded users ---
BETTER_AUTH_SECRET=generate-a-32+-char-random-string
BETTER_AUTH_URL=http://localhost:3000

# --- LLM (Fireworks + MiniMax-M3, OpenAI-compatible) ---
FIREWORKS_API_KEY=
AI_MODEL=accounts/fireworks/models/minimax-m3

# --- Image generation (Replicate GPT Image 2 with signed webhooks) ---
REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=
IMAGE_MODEL=openai/gpt-image-2
IMAGE_QUALITY=medium

# --- Internal render release evaluation (never expose to browser clients) ---
RENDER_EVAL_SERVICE_SECRET=generate-a-separate-32+-char-random-string
RENDER_EVAL_EVALUATOR_ID=approved-vision-evaluator-name-and-version

# --- Asset storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=brickpilot

# --- Rate limiting & budget guard (generous, abuse-resistant) ---
RATE_LIMIT_GEN_PER_DAY=30      # full generations per user per day
RATE_LIMIT_GEN_PER_HOUR=10
RATE_LIMIT_IMAGES_PER_DAY=20   # image generations per user per day
RATE_LIMIT_LLM_PER_HOUR=60
GLOBAL_DAILY_AI_CAP=500        # global kill-switch: total gens+images/day

# --- Seeded logins (owner + judge). No public registration. ---
SEED_OWNER_EMAIL=owner@brickpilot.demo
SEED_OWNER_PASSWORD=
SEED_JUDGE_EMAIL=judge@brickpilot.demo
SEED_JUDGE_PASSWORD=
