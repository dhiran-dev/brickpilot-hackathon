# ============================================================
# BrickPilot — environment template
# Copy to .env.local and fill in. NEVER commit the filled file.
# ============================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (SELF-HOSTED Postgres, not Neon) ---
# Example: postgresql://brickpilot:secret@localhost:5432/brickpilot
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/brickpilot

# --- Auth (better-auth) — public signup is DISABLED; only seeded users ---
BETTER_AUTH_SECRET=generate-a-32+-char-random-string
BETTER_AUTH_URL=http://localhost:3000

# --- LLM (Kimi K2 / GLM-5.2, OpenAI-compatible, MEDIUM reasoning) ---
# Provider is swappable via base URL + model. Pick one:
#   moonshot  -> https://api.moonshot.ai/v1        model: kimi-k2
#   zhipu     -> https://open.bigmodel.cn/api/paas/v4  model: glm-5.2
#   openrouter-> https://openrouter.ai/api/v1
#   fireworks -> https://api.fireworks.ai/inference/v1
LLM_PROVIDER=moonshot
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_API_KEY=
LLM_MODEL=kimi-k2
LLM_REASONING_EFFORT=medium
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_MS=30000

# --- Image generation (Replicate GPT Image 2) ---
REPLICATE_API_TOKEN=
IMAGE_MODEL=openai/gpt-image-2
IMAGE_QUALITY=medium          # low | medium | high  (main cost lever)

# --- Rate limiting & budget guard (generous, abuse-resistant) ---
RATE_LIMIT_GEN_PER_DAY=30      # full generations per user per day
RATE_LIMIT_GEN_PER_HOUR=10
RATE_LIMIT_IMAGES_PER_DAY=20   # image generations per user per day
RATE_LIMIT_LLM_PER_HOUR=60
GLOBAL_DAILY_AI_CAP=500        # global kill-switch: total gens+images/day

# --- Seeded logins (owner + judge). No public registration. ---
SEED_OWNER_EMAIL=owner@brickpilot.demo
SEED_OWNER_PASSWORD=
SEED_JUDGE_EMAIL=judge@brickpilot.demo
SEED_JUDGE_PASSWORD=
